# Omnia.AI — Backend (apps/api)
# Скопируй в .env и подставь значения. .env не коммитим.

ENV=dev
LOG_LEVEL=INFO

# --- Postgres (соответствует infra/.env: POSTGRES_USER/PASSWORD/DB) ---
DATABASE_URL=postgresql+asyncpg://omnia:omnia@localhost:5432/omnia
DATABASE_TEST_URL=postgresql+asyncpg://omnia:omnia@localhost:5432/omnia_test

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=omnia
MINIO_SECRET_KEY=omnia-secret
MINIO_SECURE=false
MINIO_BUCKET_PROJECTS=projects
MINIO_BUCKET_PREVIEWS=previews
# Публичный URL, по которому фронт получает PNG превью.
MINIO_PUBLIC_URL=http://localhost:9000

# --- JWT ---
# В проде: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-please-32-bytes-min
JWT_ALGORITHM=HS256
JWT_TTL_DAYS=7
JWT_COOKIE_NAME=omnia_session
# В проде должно быть true (HTTPS-only).
JWT_COOKIE_SECURE=false

# --- LLM Gateway ---
LLM_GATEWAY_URL=http://localhost:8001
# true — пока агент C не готов: llm_client отдаёт замокированный ответ.
MOCK_LLM=true

# --- V2 Orchestrator (Phase A) ---
# Internal-only API behind a shared X-Internal-Token header. ORCHESTRATOR_URL is
# the FastAPI service at apps/orchestrator (default :8003). Token MUST exactly
# match the one set in /opt/omnia-runtime/.env.orchestrator on the host.
# Leave token empty in dev to keep V2 routes returning 503 (no-op) — every
# orchestrator call will fail-fast with "orchestrator_unavailable".
ORCHESTRATOR_URL=http://localhost:8003
ORCHESTRATOR_INTERNAL_TOKEN=

# --- GitHub "Export to GitHub" (OAuth App) ---
# Зарегистрируй OAuth App: https://github.com/settings/applications/new
# Authorization callback URL должен совпадать с GITHUB_OAUTH_REDIRECT_URI ниже.
# Fernet-ключ для шифрования токенов:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Без GITHUB_OAUTH_CLIENT_ID + GITHUB_TOKEN_ENC_KEY эндпоинт /connect отдаёт 503.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/github/callback
GITHUB_OAUTH_SCOPES=repo
GITHUB_TOKEN_ENC_KEY=
# Переопредели, только если ходишь в GitHub через прокси (например, RU egress):
GITHUB_API_BASE=https://api.github.com
GITHUB_OAUTH_BASE=https://github.com

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Wallet ---
INITIAL_WALLET_BALANCE_RUB=100.0000
