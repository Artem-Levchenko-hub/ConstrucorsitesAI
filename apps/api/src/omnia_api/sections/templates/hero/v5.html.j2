<section id="{{ anchor_id }}" class="relative py-28 md:py-40 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    {% if s.eyebrow %}
    <p class="reveal text-sm uppercase tracking-[0.2em] font-semibold mb-8" style="color:var(--omnia-primary)">{{ s.eyebrow }}</p>
    {% endif %}
    <h1 data-anime="hero-stagger" class="display-fill font-display font-bold tracking-tight text-{{ theme.neutral }}-900 text-balance">
      {{ s.headline }}
    </h1>
    {% if s.subheadline %}
    <p class="reveal mt-10 text-xl md:text-2xl text-{{ theme.neutral }}-600 max-w-2xl leading-relaxed">{{ s.subheadline }}</p>
    {% endif %}
    <div class="reveal mt-12 flex flex-wrap items-center gap-4">
      <a href="{{ s.primary_cta.href }}" class="btn-primary inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-base hover-lift press">
        {{ s.primary_cta.label }}
      </a>
      {% if s.secondary_cta %}
      <a href="{{ s.secondary_cta.href }}" class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-{{ theme.neutral }}-700 border border-{{ theme.neutral }}-200 hover:border-{{ theme.neutral }}-300 transition-colors">
        {{ s.secondary_cta.label }}
      </a>
      {% endif %}
    </div>
  </div>
</section>
