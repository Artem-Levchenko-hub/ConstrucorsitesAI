{%- set bg_class = {'mesh':'bg-mesh', 'aurora':'bg-aurora', 'dark':''}[s.background] -%}
<section id="{{ anchor_id }}" class="relative py-28 md:py-40 overflow-hidden {{ bg_class }}" {% if s.background == 'dark' %}style="background:#0A0A0A"{% endif %}>
  <div class="absolute inset-0 pointer-events-none opacity-30" style="background-image:radial-gradient(circle at 20% 30%, var(--omnia-primary) 0%, transparent 40%), radial-gradient(circle at 80% 70%, var(--omnia-accent) 0%, transparent 45%);"></div>
  <div class="relative max-w-5xl mx-auto px-6 text-center">
    {% if s.pill_label %}
    <div class="reveal inline-flex items-center gap-2 rounded-full glass-dark px-4 py-1.5 text-sm font-medium text-white/90 mb-8">
      {{ s.pill_label }}
    </div>
    {% endif %}
    {% if s.eyebrow %}
    <p class="reveal text-sm uppercase tracking-widest font-semibold mb-6" style="color:var(--omnia-accent)">
      {{ s.eyebrow }}
    </p>
    {% endif %}
    <h1 data-anime="hero-stagger" class="display-hero font-display font-bold tracking-tight text-white text-balance">
      {{ s.headline }}
    </h1>
    {% if s.subheadline %}
    <p class="reveal mt-8 text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">
      {{ s.subheadline }}
    </p>
    {% endif %}
    <div class="reveal mt-12 flex flex-wrap items-center justify-center gap-4">
      <a href="{{ s.primary_cta.href }}" class="btn-primary glow inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-base hover-lift press">
        {{ s.primary_cta.label }}
      </a>
      {% if s.secondary_cta %}
      <a href="{{ s.secondary_cta.href }}" class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white/90 border border-white/20 hover:border-white/40 transition-colors">
        {{ s.secondary_cta.label }}
      </a>
      {% endif %}
    </div>
  </div>
</section>
