<section id="{{ anchor_id }}" class="py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center mb-16">
      {% if s.eyebrow %}<p class="reveal text-sm uppercase tracking-widest font-semibold mb-4" style="color:var(--omnia-primary)">{{ s.eyebrow }}</p>{% endif %}
      <h2 class="reveal display-xl font-display font-bold tracking-tight text-{{ theme.neutral }}-900 text-balance">{{ s.headline }}</h2>
      {% if s.subheadline %}<p class="reveal mt-5 text-lg text-{{ theme.neutral }}-600 leading-relaxed">{{ s.subheadline }}</p>{% endif %}
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-{{ s.tiers|length }} gap-6 lg:gap-8 max-w-5xl mx-auto">
      {% for t in s.tiers %}
      <div class="reveal relative rounded-2xl p-8 {% if t.featured %}ring-primary card-soft scale-[1.02]{% else %}border border-{{ theme.neutral }}-200{% endif %}" data-reveal-delay="{{ loop.index }}">
        {% if t.featured %}
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 btn-primary text-xs font-semibold px-3 py-1 rounded-full">Популярный</span>
        {% endif %}
        <h3 class="font-display text-xl font-semibold text-{{ theme.neutral }}-900">{{ t.name }}</h3>
        <div class="mt-4 flex items-baseline gap-1">
          <span class="font-display text-4xl font-bold text-{{ theme.neutral }}-900 tabular">{{ t.price }}</span>
          {% if t.period %}<span class="text-{{ theme.neutral }}-500">/{{ t.period }}</span>{% endif %}
        </div>
        <ul class="mt-6 space-y-3">
          {% for f in t.features %}
          <li class="flex gap-3 text-{{ theme.neutral }}-700">
            <svg class="w-5 h-5 flex-none mt-0.5" style="color:var(--omnia-primary)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            <span>{{ f }}</span>
          </li>
          {% endfor %}
        </ul>
        <a href="{{ t.cta.href }}" class="mt-8 inline-flex w-full items-center justify-center px-6 py-3.5 rounded-xl font-semibold {% if t.featured %}btn-primary{% else %}border border-{{ theme.neutral }}-300 text-{{ theme.neutral }}-900 hover:border-{{ theme.neutral }}-400{% endif %} press">
          {{ t.cta.label }}
        </a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
