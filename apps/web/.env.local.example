NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_USE_MOCKS=true

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

# --- Sentry ---
# Empty = SDK no-ops. In prod set to the omnia-web project DSN from sentry.io.
# The NEXT_PUBLIC_ variant ships to the client bundle; SENTRY_DSN stays server-only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_ENV=dev
# SENTRY_AUTH_TOKEN — only set in CI for source-map upload; never local.
SENTRY_AUTH_TOKEN=
