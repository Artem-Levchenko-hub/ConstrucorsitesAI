# Dev image — used by orchestrator for the per-project dev container.
# Builds once at template-cache time; project files mount as volumes so
# AI edits are picked up by Turbopack HMR without rebuild.

FROM node:20-alpine

WORKDIR /app

# Allow non-root user for the orchestrator's --user 1000:1000 flag.
RUN apk add --no-cache libc6-compat \
    && addgroup -g 1000 omnia \
    && adduser -D -u 1000 -G omnia omnia

# Install pnpm (Next 15 + Turbopack work cleanly with it).
RUN corepack enable && corepack prepare pnpm@9 --activate

# Pre-install dependencies to warm the layer cache. The orchestrator
# bind-mounts /app/src and /app/drizzle on top of the template at run time
# so AI writes show up immediately.
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

COPY . .

USER omnia
EXPOSE 3000

# Default: hot-reload dev server. Container envs (DATABASE_URL, etc.)
# come from the orchestrator at run time.
CMD ["pnpm", "dev"]
