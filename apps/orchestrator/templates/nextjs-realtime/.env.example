# Postgres DSN for the per-project schema (injected by the orchestrator).
DATABASE_URL=postgres://user:pass@localhost:5432/app

# JWT signing secret for Auth.js (generated per project at provision time).
# Rotate to force a global sign-out.
AUTH_SECRET=replace-with-a-32-byte-random-secret

# Optional: enable cross-replica realtime fan-out in production. Without it the
# in-process hub serves a single container correctly (the dev preview default).
# REDIS_URL=redis://localhost:6379
