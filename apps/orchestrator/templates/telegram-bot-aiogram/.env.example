# Per-container envs injected by orchestrator at run time.
# Don't commit real values — this file just documents the contract.

# REQUIRED — user provides via Omnia secrets panel.
# Bot won't work without it (the health server still comes up so the
# container shows "running", but no Telegram interactions happen).
TELEGRAM_BOT_TOKEN=

# Provided by orchestrator (postgres_admin per-project schema).
DATABASE_URL=postgresql://proj_user:secret@host.docker.internal:5433/omnia_users?options=-c+search_path%3Dproj_xxxxxxxx
