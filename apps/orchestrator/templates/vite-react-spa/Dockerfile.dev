# Dev image for the Vite + React SPA template.
# Same Debian-slim + node:22 base as nextjs-postgres-drizzle so a single
# image-cache layer is shared between templates on the VPS.

FROM node:22-slim

WORKDIR /app
RUN chown -R node:node /app

# pnpm for consistency with the Next template.
RUN corepack enable && corepack prepare pnpm@9 --activate

USER node

COPY --chown=node:node package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

COPY --chown=node:node . .

EXPOSE 3000

# Vite dev server hot-reloads on bind-mount changes. No DB sync step
# needed (this template has no backend) — much simpler than the Next
# template's entrypoint.
CMD ["pnpm", "dev"]
