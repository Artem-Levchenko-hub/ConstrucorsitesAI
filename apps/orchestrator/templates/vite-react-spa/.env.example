# Per-container envs injected by orchestrator at run time.
# Don't commit real values — this file just documents the contract.

NODE_ENV=development
# Public-facing URL for the dev container. Used by the AI when generating
# canonical OG URLs or self-referential links. Same shape as the
# nextjs-postgres-drizzle template's PUBLIC_URL.
PUBLIC_URL=https://<slug>-dev.preview.lead-generator.ru
