# Per-container envs injected by orchestrator at run time.
# Don't commit real values — this file just documents the contract.

# Orchestrator-provided (postgres_admin per-project schema).
DATABASE_URL=postgresql://proj_user:secret@host.docker.internal:5433/omnia_users?options=-c+search_path%3Dproj_xxxxxxxx

# JWT signing key. Same value as Next-template's AUTH_SECRET — orchestrator
# loads/persists at `secrets_root/<project_id>/auth.secret` so token signatures
# survive container restarts. The app refuses to start if this is missing or
# shorter than 16 chars (validate_runtime_config in main.py).
AUTH_SECRET=

# Optional: comma-separated frontend origins allowed to call this API via CORS
# (e.g. https://app.example.com,https://admin.example.com). Leave empty for
# same-origin only. NEVER use "*" with credentials.
ALLOWED_ORIGINS=
