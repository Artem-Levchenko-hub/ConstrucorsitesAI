# Dev image for the BARE / NO-STACK experiment (owner 2026-06-30 «опус никак не
# ограничен субстратом или стеком, пишет как ему скажут»). This is a generic
# Linux dev box — NOT a framework scaffold. There is NO app, NO package.json, NO
# substrate. The agent picks ANY stack from the raw prompt, scaffolds it via bash,
# and starts its OWN dev server on :3000. The full toolset (build/probe/see/
# runtime_check/read_logs/docs/bash/file-ops) is in the agent loop, not here.
#
# Debian-slim (not Alpine) — Alpine's CDN is blocked by some Russian DPI.

FROM node:22-slim

# System toolchain: Node 22 + pnpm (corepack), Python 3 + pip, git/curl, and a
# C toolchain for native deps. Enough for the agent to scaffold ANY mainstream
# web stack (Next/Remix/SvelteKit/Astro/Express/Hono/Nuxt, or FastAPI/Flask).
USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv git curl ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable && corepack prepare pnpm@9 --activate

WORKDIR /app
RUN chown -R node:node /app
USER node

COPY --chown=node:node docker-entrypoint.sh ./
RUN chmod +x docker-entrypoint.sh

EXPOSE 3000

# Keep the container alive; the AGENT starts its own dev server (see
# SYSTEM_PROMPT). Container envs (DATABASE_URL, REDIS_URL, AUTH_SECRET, ...) come
# from the orchestrator.
CMD ["./docker-entrypoint.sh"]
