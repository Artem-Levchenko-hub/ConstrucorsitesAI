# Dev image for the BARE experiment stack (owner 2026-06-30 «отключим шаблоны,
# Opus строит с нуля»). A blank, runnable Next.js 15 app — NO substrate: no auth
# wiring, no DB schema, no entity engine, no realtime hub, no component kit. The
# agent writes EVERYTHING from the raw prompt. This is the control for the
# "do templates oppress the model?" hypothesis.
#
# Debian-slim (not Alpine) — Alpine's CDN is blocked by some Russian DPI.

FROM node:22-slim

WORKDIR /app
RUN chown -R node:node /app

RUN corepack enable && corepack prepare pnpm@9 --activate

USER node

# Warm the dependency layer. No lockfile shipped -> the `||` falls back to a
# non-frozen install that resolves the ranges in package.json.
COPY --chown=node:node package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

COPY --chown=node:node . .

RUN chmod +x docker-entrypoint.sh

EXPOSE 3000

# Just the dev server — NO init-db. There is no fixed schema; if the app the
# agent builds needs tables, the agent writes its own init. Container envs
# (DATABASE_URL, REDIS_URL, AUTH_SECRET, ...) come from the orchestrator.
CMD ["./docker-entrypoint.sh"]
