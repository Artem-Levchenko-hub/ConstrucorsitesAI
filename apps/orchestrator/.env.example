# Omnia.AI V2 Orchestrator — local dev defaults.
# Copy to .env; production values go in /opt/omnia-runtime/.env.orchestrator.

ENV=dev
LOG_LEVEL=INFO

# Shared Postgres for user projects (not the V1 omnia-mvp DB).
# Phase A: separate instance on port 5433 to keep user DBs isolated from app DB.
DATABASE_URL=postgresql+asyncpg://omnia_root:omnia-users-pass@localhost:5433/omnia_users

# Docker socket. On prod Linux: unix:///var/run/docker.sock.
# Local Windows/macOS dev: usually npipe:// or tcp://localhost:2375 (insecure).
DOCKER_HOST=unix:///var/run/docker.sock

# Project filesystem layout — see docs/08-vps-setup.md.
PROJECTS_ROOT=/opt/omnia-runtime/projects
NGINX_SITES_DIR=/opt/omnia-runtime/nginx/sites-enabled
SECRETS_ROOT=/opt/omnia-runtime/secrets

# Local Docker registry for prod deploy images.
REGISTRY_URL=127.0.0.1:5000

# Wildcard domain. *.omnia.app A → VPS IP. Needs DNS to point here BEFORE
# the orchestrator boots, otherwise nginx reload will succeed but TLS fails.
BASE_DOMAIN=omnia.app

# Port range for dev containers. Pick from this pool, write to nginx config.
PORT_RANGE_MIN=3001
PORT_RANGE_MAX=3999

# Hibernate policy (minutes of inactivity before pause/stop).
HIBERNATE_FREE_TIER_MINUTES=15
HIBERNATE_PRO_TIER_MINUTES=60
WAKE_TIMEOUT_SECONDS=60

# Shared secret with apps/api — request header X-Internal-Token must match.
# Generate: openssl rand -hex 32
INTERNAL_TOKEN=dev-internal-token-change-me

# Sentry — empty disables.
SENTRY_DSN=
