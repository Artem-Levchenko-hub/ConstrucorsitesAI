# Omnia.AI V2 Orchestrator — local dev defaults.
# Copy to .env; production values go in /opt/omnia-runtime/.env.orchestrator.

ENV=dev
LOG_LEVEL=INFO

# Shared Postgres for user projects (NOT the V1 omnia-mvp app DB).
# Phase A: separate instance on port 5433 to keep user DBs isolated.
# Used by `core.postgres_admin` as ADMIN connection to create per-project
# schemas + roles. The DSN handed to each user container is derived from this
# (host substituted to `host.docker.internal`, creds replaced with project role).
DATABASE_URL=postgresql+asyncpg://omnia_root:omnia-users-pass@localhost:5433/omnia_users

# Docker socket. On prod Linux: unix:///var/run/docker.sock.
# Local Windows/macOS dev: usually npipe:// or tcp://localhost:2375 (insecure).
DOCKER_HOST=unix:///var/run/docker.sock

# Project filesystem layout — see docs/08-vps-setup.md.
PROJECTS_ROOT=/opt/omnia-runtime/projects
NGINX_SITES_DIR=/opt/omnia-runtime/nginx/sites-enabled
SECRETS_ROOT=/opt/omnia-runtime/secrets

# Local Docker registry for prod deploy images.
REGISTRY_URL=127.0.0.1:5000

# Legacy: kept for backward compat with any tooling that reads BASE_DOMAIN.
# Active config is `RUNTIME_HOST_SUFFIX` below — defaults to the sslip.io
# wildcard which needs ZERO DNS setup. Switch only after proper wildcard A-records
# for the chosen apex exist.
BASE_DOMAIN=omniadevelop.ru

# Public hostname suffix used by `nginx_writer` for dev/prod URLs:
#   dev preview → "{slug}-dev.{suffix}"      prod deploy → "{slug}.{suffix}"
# Default resolves anything *.170-168-72-200.sslip.io to the prod VPS without
# any registrar setup. Change to "app.lead-generator.ru" or equivalent once
# real wildcard DNS is in place.
RUNTIME_HOST_SUFFIX=170-168-72-200.sslip.io

# Port range for dev containers. 3001-3199 are reserved for V1 (omnia-prod-web :3100)
# and other tenants (endless-war :3030). 3200+ is V2 territory.
PORT_RANGE_MIN=3200
PORT_RANGE_MAX=3999

# Hibernate policy (minutes of inactivity before pause/stop).
HIBERNATE_FREE_TIER_MINUTES=15
HIBERNATE_PRO_TIER_MINUTES=60
WAKE_TIMEOUT_SECONDS=60

# Shared secret with apps/api — request header X-Internal-Token must match.
# Generate: openssl rand -hex 32
INTERNAL_TOKEN=dev-internal-token-change-me

# Sentry — empty disables.
SENTRY_DSN=
