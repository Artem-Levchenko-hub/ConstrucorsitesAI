# Full-stack production demo .env. Copy to .env and fill the marked secrets.

# === public-facing URL (used by frontend build args + api CORS) ===
PUBLIC_ORIGIN=https://constructor.lead-generator.ru
PUBLIC_WS_ORIGIN=wss://constructor.lead-generator.ru

# === host ports — must be free on the box ===
GATEWAY_HOST_PORT=8101
API_HOST_PORT=8200
WEB_HOST_PORT=3100

# === infra credentials (internal — postgres/minio not exposed to host) ===
POSTGRES_USER=omnia
POSTGRES_PASSWORD=omnia
POSTGRES_DB=omnia

MINIO_ROOT_USER=omnia
MINIO_ROOT_PASSWORD=please-change-to-32-random-chars
MINIO_BUCKET_PROJECTS=projects
MINIO_BUCKET_PREVIEWS=previews
MINIO_PUBLIC_URL=https://constructor.lead-generator.ru/minio

# === required app secrets (generate via `openssl rand -base64 32`) ===
JWT_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# === LLM provider keys ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
OPENROUTER_API_KEY=
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false

# === gateway behavior ===
DEFAULT_MODEL=gigachat-2
SAFETY_FILTER_ENABLED=true
CACHE_TTL_SECONDS=3600
MIN_BALANCE_RUB=5.0

# === api behavior ===
INITIAL_WALLET_BALANCE_RUB=100.0

# === logging ===
LOG_LEVEL=INFO
