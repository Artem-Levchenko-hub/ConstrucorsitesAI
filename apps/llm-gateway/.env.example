# Provider API keys (leave blank to disable a provider — gateway will report it as unavailable in /v1/models)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
OPENROUTER_API_KEY=

# Sber GigaChat — see providers/sber.py
GIGACHAT_AUTH_KEY=                    # base64(client_id:client_secret) from Sber developer cabinet
GIGACHAT_SCOPE=GIGACHAT_API_PERS      # or GIGACHAT_API_CORP for corporate accounts
GIGACHAT_VERIFY_SSL=false             # true only if Sber's Russian Trusted Root cert is in your CA bundle

# Shared infrastructure (same Postgres as apps/api per AGENT-C brief, variant 1)
DATABASE_URL=postgresql://omnia:omnia@localhost:5432/omnia
REDIS_URL=redis://localhost:6379/1

# Behavior
DEFAULT_MODEL=claude-sonnet-4-6
SAFETY_FILTER_ENABLED=true
CACHE_TTL_SECONDS=3600
MIN_BALANCE_RUB=5.0
REQUEST_TIMEOUT_SECONDS=60

LOG_LEVEL=INFO

# Host port to bind the gateway on (override if 8001 is already taken)
GATEWAY_HOST_PORT=8001
