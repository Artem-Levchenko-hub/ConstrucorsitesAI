# Omnia.AI — production env template
# Copy to .env.prod on the VPS, fill in real values, never commit.
# Used by `docker compose --env-file .env.prod up -d`.

# --- Database / Storage ---
POSTGRES_USER=omnia
POSTGRES_PASSWORD=<openssl rand -hex 32>
POSTGRES_DB=omnia
MINIO_ROOT_USER=omnia
MINIO_ROOT_PASSWORD=<openssl rand -hex 32>
MINIO_BUCKET_PROJECTS=projects
MINIO_BUCKET_PREVIEWS=previews

# Public URL where the browser fetches preview PNGs. In prod this is nginx
# serving MinIO with TLS — never the raw minio:9000 endpoint.
MINIO_PUBLIC_URL=https://constructor.lead-generator.ru/minio

# --- JWT ---
# `openssl rand -hex 32` — never reuse the dev value.
JWT_SECRET=<openssl rand -hex 32>
# P0-2: MUST be true in any environment terminating HTTPS. Cookie is set
# with the Secure flag → browser refuses to send it over plain HTTP.
JWT_COOKIE_SECURE=true

# --- LLM Gateway ---
LLM_GATEWAY_URL=http://llm-gateway:8001
# Set to false once real provider keys are wired up.
MOCK_LLM=false

# --- CORS ---
# Whitelist of prod-only origins. Strip http://localhost:3000 before deploying.
CORS_ORIGINS=https://constructor.lead-generator.ru

# --- Wallet ---
INITIAL_WALLET_BALANCE_RUB=100.0000

# --- Rate limiting ---
# P0-1: must be true in any internet-facing environment.
RATE_LIMIT_ENABLED=true

# --- Sentry (error tracking) ---
# Three separate projects on sentry.io (omnia-api, omnia-gateway, omnia-web).
# Empty value → SDK no-ops; never accidentally inits with a leftover dev DSN.
ENV=prod
SENTRY_DSN_API=
SENTRY_DSN_GATEWAY=
NEXT_PUBLIC_SENTRY_DSN=

# ==============================================================================
# nginx — required snippets (place under server { listen 443 ssl; ... })
# ==============================================================================
#
# HSTS — 1 year, includes subdomains, preload-ready. Add ONLY after you're sure
# every subdomain you control will be HTTPS-only forever; rolling this back means
# users with cached HSTS will be locked out of HTTP fallback for `max-age` seconds.
#
#   add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
#
# Proxy-headers (api container reads X-Forwarded-For via uvicorn's
# ProxyHeadersMiddleware — without these, slowapi sees every request as nginx's IP):
#
#   location /api/ {
#       proxy_pass         http://omnia-api:8000;
#       proxy_set_header   Host              $host;
#       proxy_set_header   X-Real-IP         $remote_addr;
#       proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
#       proxy_set_header   X-Forwarded-Proto $scheme;
#   }
#
# WebSocket upgrade for /api/ws/:
#
#   location /api/ws/ {
#       proxy_pass         http://omnia-api:8000;
#       proxy_http_version 1.1;
#       proxy_set_header   Upgrade           $http_upgrade;
#       proxy_set_header   Connection        "Upgrade";
#       proxy_set_header   Host              $host;
#       proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
#       proxy_read_timeout 86400;
#   }
#
# Verification after deploy:
#   curl -I https://constructor.lead-generator.ru/api/auth/me
#     → expect: Set-Cookie includes "Secure; HttpOnly; SameSite=Lax"
#     → expect: Strict-Transport-Security header present
#   for i in {1..6}; do curl -X POST .../api/auth/login -d '{...}' ; done
#     → expect: 6th request returns 429 with {"error":{"code":"rate_limited",...}}
