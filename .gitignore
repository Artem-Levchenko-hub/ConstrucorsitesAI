# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/
__pycache__/
*.py[cod]
.venv/
venv/

# Build outputs
.next/
dist/
build/
*.egg-info/
# Landing snapshot lives in apps/landing/dist/ — it's NOT a build output of
# this monorepo, it's a tracked snapshot pulled from the production VPS so
# we can review/diff/rollback the landing bundle here. Override the global
# dist/ rule for that specific path.
!apps/landing/dist/
!apps/landing/dist/**

# Env / secrets
.env
.env.local
.env.*.local
!.env.example

# IDE
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS
.DS_Store
Thumbs.db

# Worktrees (управляются claude-session-driver)
.claude/worktrees/

# Local data (для docker-compose volumes)
infra/data/

# Test artifacts
playwright-report/
test-results/
coverage/

# Generated backups (env + docker-compose) — never commit, may contain secrets
.env.bak
.env.bak.*
**/.env.bak.*
docker-compose.yml.bak.*
**/docker-compose.yml.bak.*
